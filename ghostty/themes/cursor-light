# Cursor Light — A Ghostty theme matching the cursor-light nvim colorscheme
#
# Colors sourced from vpoltora/cursor-light.nvim palette for consistency
# across Ghostty, tmux, and Neovim.
#
# Installation:
#   1. Copy this file to ~/.config/ghostty/themes/
#   2. In ~/.config/ghostty/config, set:
#        theme = cursor-light
#      Or pair with cursor-night for automatic light/dark switching:
#        theme = light:cursor-light,dark:cursor-night
#   3. Restart Ghostty

# Core colors
background = #FCFCFC
foreground = #141414
cursor-color = #141414
cursor-text = #FCFCFC
selection-background = #E8E8E8
selection-foreground = #141414

# ANSI Normal (0-7)
palette = 0=#141414
palette = 1=#B31B3F
palette = 2=#1F8A65
palette = 3=#C08532
palette = 4=#206595
palette = 5=#B8448B
palette = 6=#4C7F8C
palette = 7=#6F6F6F

# ANSI Bright (8-15)
palette = 8=#555555
palette = 9=#CF2D56
palette = 10=#55A583
palette = 11=#DB704B
palette = 12=#6299C3
palette = 13=#D06BA6
palette = 14=#6F9BA6
palette = 15=#999999
